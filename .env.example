DATABASE_URL="postgresql://postgres:password@localhost:5432/taskmanager"
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Pusher — real-time cross-device sync (optional; SSE is used as fallback in dev without these)
# Create a free app at pusher.com/channels, then copy App ID, Key, Secret, Cluster
PUSHER_APP_ID="your-app-id"
PUSHER_KEY="your-app-key"
PUSHER_SECRET="your-app-secret"
PUSHER_CLUSTER="mt1"
